# Required
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
BETTER_AUTH_SECRET=<generate-random-32-char-secret>

# Optional: External PostgreSQL (embedded DB used if not set)
# DATABASE_URL=postgresql://user:pass@host:5432/paperclip

# Optional: Public URL for OAuth callbacks
# PAPERCLIP_PUBLIC_URL=https://your-app.up.railway.app

# Optional: Storage (S3 for attachments)
# PAPERCLIP_STORAGE_PROVIDER=s3
# PAPERCLIP_STORAGE_S3_BUCKET=my-bucket
# PAPERCLIP_STORAGE_S3_REGION=us-east-1
